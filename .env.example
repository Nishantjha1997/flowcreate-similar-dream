# ============================================================================
# FlowCreate — Frontend environment template
# Copy to .env and fill in values from your NEW Supabase project:
# Dashboard -> Project Settings -> API
#
# The browser client reads the VITE_ values below. Keep secrets out of VITE_
# variables: Vite exposes them in the built JavaScript bundle.
# ============================================================================

# --- Supabase (frontend, safe to expose) ---
VITE_SUPABASE_URL="https://<project-ref>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<anon-key>"
VITE_SUPABASE_PROJECT_ID="<project-ref>"

# Legacy aliases some tooling reads (keep in sync with the VITE_ values)
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_PUBLISHABLE_KEY="<anon-key>"

# ============================================================================
# Edge Function secrets — these are NOT frontend variables. Set them with:
#   supabase secrets set KEY=value
# or Dashboard -> Edge Functions -> Secrets. Never put them in this file's
# .env copy or commit them anywhere.
#
#   SUPABASE_URL                <auto-provided by Supabase>
#   SUPABASE_ANON_KEY           <auto-provided by Supabase>
#   SUPABASE_SERVICE_ROLE_KEY   <auto-provided by Supabase>
#
#   # Razorpay (existing India flow + new webhook)
#   RAZORPAY_KEY_ID             rzp_test_... / rzp_live_...
#   RAZORPAY_KEY_SECRET         ...
#   RAZORPAY_WEBHOOK_SECRET     set when creating the webhook in Razorpay dashboard
#
#   # Stripe (new global flow)
#   STRIPE_SECRET_KEY           sk_test_... / sk_live_...
#   STRIPE_WEBHOOK_SECRET       whsec_... (from Stripe webhook endpoint config)
#
#   # AI
#   GEMINI_API_KEY              Google AI Studio key
#   BLOG_SCHEDULER_SECRET       random 32+ byte secret used only by Supabase Cron
#   VERCEL_DEPLOY_HOOK_URL      optional; rebuilds sitemap after an auto-publish
#
#   # Notifications / email
#   RESEND_API_KEY              re_... (optional; emails skipped if unset)
#   NOTIFY_FROM_EMAIL           "FlowCreate <notifications@yourdomain.com>"
#
#   # Misc
#   SITE_URL                    https://yourdomain.com (checkout redirects)
# ============================================================================
# Canonical public origin. Change this once when a custom domain goes live;
# canonicals, Open Graph URLs, the sitemap, RSS feed, and structured data all
# follow it automatically. Do not include a trailing slash.
VITE_SITE_URL=https://flowcreate-similar-dream.vercel.app
